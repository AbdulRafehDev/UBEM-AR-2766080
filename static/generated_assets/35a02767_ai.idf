ZONECONTROL:THERMOSTAT,
    Dynamic_Zone Thermostat,    !- Name
    Dynamic_Zone,             !- Zone or ZoneList Name
    Yearly Thermostat,        !- Control Type Schedule Name
    ThermostatSetpoint:DualSetpoint,    !- Control 1 Object Type
    Dual Setpoint - Dynamic_Zone,    !- Control 1 Name
    ,                         !- Control 2 Object Type
    ,                         !- Control 2 Name
    ,                         !- Control 3 Object Type
    ,                         !- Control 3 Name
    ,                         !- Control 4 Object Type
    ,                         !- Control 4 Name
    0;                        !- Temperature Difference Between Cutout And Setpoint

THERMOSTATSETPOINT:DUALSETPOINT,
    Dual Setpoint - Dynamic_Zone,    !- Name
    Zone Heating Setpoint Schedule,    !- Heating Setpoint Temperature Schedule Name
    Zone Cooling Setpoint Schedule;    !- Cooling Setpoint Temperature Schedule Name

ZONEHVAC:IDEALLOADSAIRSYSTEM,
    Dynamic_Zone IdealLoads,    !- Name
    Always On,                !- Availability Schedule Name
    Dynamic_Zone SupplyAirNode,    !- Zone Supply Air Node Name
    ,                         !- Zone Exhaust Air Node Name
    ,                         !- System Inlet Air Node Name
    50,                       !- Maximum Heating Supply Air Temperature
    13,                       !- Minimum Cooling Supply Air Temperature
    0.015,                    !- Maximum Heating Supply Air Humidity Ratio
    0.009,                    !- Minimum Cooling Supply Air Humidity Ratio
    NoLimit,                  !- Heating Limit
    ,                         !- Maximum Heating Air Flow Rate
    ,                         !- Maximum Sensible Heating Capacity
    NoLimit,                  !- Cooling Limit
    ,                         !- Maximum Cooling Air Flow Rate
    ,                         !- Maximum Total Cooling Capacity
    ,                         !- Heating Availability Schedule Name
    ,                         !- Cooling Availability Schedule Name
    ConstantSupplyHumidityRatio,    !- Dehumidification Control Type
    0.7,                      !- Cooling Sensible Heat Ratio
    ConstantSupplyHumidityRatio,    !- Humidification Control Type
    ,                         !- Design Specification Outdoor Air Object Name
    ,                         !- Outdoor Air Inlet Node Name
    None,                     !- Demand Controlled Ventilation Type
    NoEconomizer,             !- Outdoor Air Economizer Type
    None,                     !- Heat Recovery Type
    0.7,                      !- Sensible Heat Recovery Effectiveness
    0.65;                     !- Latent Heat Recovery Effectiveness

ZONEHVAC:EQUIPMENTLIST,
    Dynamic_Zone EquipmentList,    !- Name
    SequentialLoad,           !- Load Distribution Scheme
    ZoneHVAC:IdealLoadsAirSystem,    !- Zone Equipment 1 Object Type
    Dynamic_Zone IdealLoads,    !- Zone Equipment 1 Name
    1,                        !- Zone Equipment 1 Cooling Sequence
    1;                        !- Zone Equipment 1 Heating or NoLoad Sequence

ZONEHVAC:EQUIPMENTCONNECTIONS,
    Dynamic_Zone,             !- Zone Name
    Dynamic_Zone EquipmentList,    !- Zone Conditioning Equipment List Name
    Dynamic_Zone SupplyAirNode,    !- Zone Air Inlet Node or NodeList Name
    ,                         !- Zone Air Exhaust Node or NodeList Name
    Dynamic_Zone ZoneAirNode,    !- Zone Air Node Name
    Dynamic_Zone ZoneReturnAirNode;    !- Zone Return Air Node or NodeList Name

OUTPUT:VARIABLE,
    *,                        !- Key Value
    Zone Ideal Loads Supply Air Total Heating Energy,    !- Variable Name
    Annual;                   !- Reporting Frequency

OUTPUT:VARIABLE,
    *,                        !- Key Value
    Zone Ideal Loads Supply Air Total Cooling Energy,    !- Variable Name
    Annual;                   !- Reporting Frequency